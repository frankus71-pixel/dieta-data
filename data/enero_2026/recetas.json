      "ingredientes": [
        "Huevo 60g",
        "Jamon Cocido 40g",
        "Aceite De Oliva 5g",
        "Sal"
      ],
      "preparacion": "Batir huevo con sal. Añadir a sarten con aceite. Incorporar jamon y cuajar por ambos lados."
