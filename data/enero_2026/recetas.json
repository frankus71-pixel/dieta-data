    {
      "id": "espaguetis_marineros",
      "nombre": "Espaguetis Marineros",
      "ingredientes": [
        "Espagueti Integral 150g",
        "Langostinos 100g",
        "Ajo 5g",
        "Perejil 10g",
        "Vino Blanco 80g",
        "Aceite De Oliva 10g",
        "Sal"
      ],
      "preparacion": "Hervir los espaguetis en agua con sal. En una sarten con aceite dorar el ajo, añadir el vino y reducir. Incorporar langostinos y perejil, saltear 2-3 minutos. Mezclar con la pasta."
    },
    {
